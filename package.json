{
  "name": "node-fastify-template",
  "version": "1.0.0",
  "description": "A Node.js template using Fastify and PostgreSQL for a quick startup project",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "NODE_ENV=production tsx -r tsconfig-paths/register server.ts",
    "dev": "NODE_ENV=development nodemon --exec 'tsx -r tsconfig-paths/register' server.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "check": "npm run type-check && npm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "typeorm": "ts-node-esm -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/Init -d src/config/database.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/database.ts",
    "test:coverage": "jest --coverage",
    "test:db": "jest --detectOpenHandles --forceExit __tests__/integration/database.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:g-guerzoni/node-fastify-template.git"
  },
  "author": "Abdurakhmonov Sharif",
  "license": "MIT",
  "dependencies": {
    "@scalar/fastify-api-reference": "^1.35.6",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.18.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
